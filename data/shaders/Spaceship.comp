layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(rgba16f, set = 0, binding = 0) uniform image2D uTarget;

layout(push_constant) uniform Push
{
    float time;
    float _pad0;
    vec2 resolution;
    vec4 mouse;
} push;

#define iTime push.time
#define iResolution vec3(push.resolution, 1.0)
#define iMouse push.mouse

//#define LESSDETAIL

#define RAY_STEPS 100
#define SHADOW_STEPS 50
#define LIGHT_COLOR vec3(1.0, 0.97, 0.93)
#define AMBIENT_COLOR vec3(0.75, 0.65, 0.6)
#define SPECULAR 0.65
#define DIFFUSE 1.0
#define AMBIENT 0.35
#define detail 0.00004
#define t (iTime * 0.2)

vec3 lightdir = normalize(vec3(0.1, -0.15, -1.0));
const vec3 origin = vec3(-1.0, 0.2, 0.0);

mat2 rot(float a)
{
    float c = cos(a);
    float s = sin(a);
    return mat2(c, s, -s, c);
}

const vec3 kNeonGreen = vec3(0.2, 1.0, 0.15);

