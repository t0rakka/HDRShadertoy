vec3 tex3D(in vec3 p, in vec3 n)
{
    return kSurfaceColor;
}

float map(vec3 p)
{
    const vec3 offs = vec3(1.0, 0.75, 0.5);
    const vec2 a = sin(vec2(0.0, 1.57079632) + 1.57 / 2.0);
    const mat2 m = mat2(a.y, -a.x, a);
    const vec2 a2 = sin(vec2(0.0, 1.57079632) + 1.57 / 4.0);
    const mat2 m2 = mat2(a2.y, -a2.x, a2);
    const float s = 5.0;
    const float sz = 0.0355;
#ifdef WIREFRAME
    const float ew = 0.015;
#endif

    float d = 1e5;

    p = abs(fract(p * 0.5) * 2.0 - 1.0);
    float amp = 1.0 / s;

    for (int i = 0; i < 2; i++)
    {
        p.xy = m * p.xy;
        p.yz = m2 * p.yz;
        p = abs(p);

        p.xy += step(p.x, p.y) * (p.yx - p.xy);
        p.xz += step(p.x, p.z) * (p.zx - p.xz);
        p.yz += step(p.y, p.z) * (p.zy - p.yz);

        p = p * s + offs * (1.0 - s);
        p.z -= step(p.z, offs.z * (1.0 - s) * 0.5) * offs.z * (1.0 - s);

        p = abs(p);
        vec3 q = p * amp;
        float box = max(max(q.x, q.y), q.z) - sz;
#ifdef WIREFRAME
        box = max(box, -(min(min(max(q.x, q.y), max(q.x, q.z)), max(q.y, q.z)) - sz + ew));
#endif
        d = min(d, box);
        amp /= s;
    }

    return d;
}

