vec3 envMap(vec3 rd, vec3 n)
{
    return smoothstep(0.1, 1.0, kEnvColor * kEnvColor * 2.0);
}

void mainImage(out vec4 fragColor, in vec2 fragCoord)
{
    vec3 rd = vec3(2.0 * fragCoord - iResolution.xy, iResolution.y);
    rd = normalize(vec3(rd.xy, sqrt(rd.z * rd.z - dot(rd.xy, rd.xy) * 0.2)));

    vec2 m = sin(vec2(1.57079632, 0.0) + iTime / 4.0);
    rd.xy = rd.xy * mat2(m.xy, -m.y, m.x);
    rd.xz = rd.xz * mat2(m.xy, -m.y, m.x);

    vec3 ro = vec3(0.0, 0.0, iTime);
    vec3 lp = ro + vec3(0.0, 0.25, 0.65);
    vec3 col = vec3(0.0);

    float t = trace(ro, rd);

    if (t < FAR)
    {
        vec3 sp = ro + rd * t;
        vec3 sn = normal(sp);

        const float sz = 1.5;
        sn = db(sp * sz, sn, 0.004 / (1.0 + t / FAR * 0.5));

        vec3 oCol = tex3D(sp * sz, sn);
        oCol = smoothstep(0.0, 0.8, oCol);

        float sh = softShadow(sp, lp, 16.0);
        float ao = calculateAO(sp, sn) * 0.5 + 0.5;

        vec3 ld = lp - sp;
        float lDist = max(length(ld), 0.001);
        ld /= lDist;

        float diff = max(dot(ld, sn), 0.0);
        float spec = pow(max(dot(reflect(-ld, sn), -rd), 0.0), 12.0);
        float atten = 1.0 / (1.0 + lDist * 0.25 + lDist * lDist * 0.075);

        col = oCol * (diff + vec3(0.4, 0.25, 0.2) + vec3(1.0, 0.6, 0.2) * spec * 8.0);
        col += (col * 1.0 + 0.5) * envMap(reflect(rd, sn), sn);
        col = col * atten * sh * ao;
    }

    float mist = getMist(ro, rd, lp, t);
    vec3 sky = mix(vec3(1.0, 0.75, 0.5), vec3(0.35, 0.6, 1.0), dot(rd.yz, vec2(0.5)) * 0.5 + 0.5) * mix(1.0, 0.75, mist);
    col = mix(sky, col, 1.0 / (t * t / FAR / FAR * 128.0 + 1.0));

    fragColor = vec4(max(col, vec3(0.0)), 1.0);
}

void main()
{
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(uTarget);
    if (pixel.x >= size.x || pixel.y >= size.y)
    {
        return;
    }

    vec4 fragColor;
    vec2 fragCoord = vec2(float(pixel.x), float(size.y - pixel.y - 1)) + 0.5;
    mainImage(fragColor, fragCoord);
    imageStore(uTarget, pixel, vec4(fragColor.rgb, 1.0));
}
