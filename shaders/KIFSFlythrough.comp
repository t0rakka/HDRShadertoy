#version 450

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(rgba16f, set = 0, binding = 0) uniform image2D uTarget;

layout(push_constant) uniform Push
{
    float time;
    float _pad0;
    vec2 resolution;
    vec4 mouse;
} push;

#define iTime push.time
#define iResolution vec3(push.resolution, 1.0)
#define iMouse push.mouse

// KIFS Flythrough — Shane
// https://www.shadertoy.com/view/4sl3RX

#define FAR 40.0

//#define WIREFRAME

const vec3 kSurfaceColor = vec3(0.75, 0.72, 0.68);
const vec3 kEnvColor = vec3(0.35, 0.6, 1.0);

float hash1(float n)
{
    return fract(cos(n) * 45758.5453);
}

